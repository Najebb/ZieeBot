# # ============================================
# # Environment Variables - Jebb Bot
# # Copy file ini jadi .env dan isi dengan data kamu
# # ============================================

# # Token bot Discord (Dapatkan dari https://discord.com/developers/applications)
# DISCORD_TOKEN=token_bot_kamu_di_sini

# # Application ID / Client ID bot (Dari Discord Developer Portal)
# CLIENT_ID=application_id_bot_kamu

# # ID Discord Owner (Kamu) - Untuk heartbeat & command /addxp
# # Cara dapat: Aktifkan Developer Mode → Right click profil → Copy User ID
# OWNER_ID=id_discord_kamu_18_digit

